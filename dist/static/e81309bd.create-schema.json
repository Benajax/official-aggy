[
  {
    "fields": [
      {
        "name": "name",
        "type": "string",
        "title": "Artist Name"
      },
      {
        "options": {
          "accept": "video/mp4"
        },
        "name": "heroVideo",
        "type": "file"
      },
      {
        "of": [
          {
            "options": {
              "accept": "video/*"
            },
            "type": "file"
          }
        ],
        "name": "heroVideoPool",
        "type": "array"
      },
      {
        "options": {
          "hotspot": true
        },
        "name": "logoImg",
        "type": "image",
        "title": "Logo Image"
      },
      {
        "name": "logoText",
        "type": "string"
      }
    ],
    "name": "artist",
    "type": "document"
  },
  {
    "fields": [
      {
        "name": "city",
        "type": "string"
      },
      {
        "name": "venue",
        "type": "string"
      },
      {
        "name": "date",
        "type": "datetime"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "name": "ticketUrl",
        "type": "url",
        "title": "Ticket URL"
      }
    ],
    "name": "tourDate",
    "type": "document"
  },
  {
    "fields": [
      {
        "options": {
          "hotspot": true
        },
        "name": "image",
        "type": "image",
        "title": "Post Image"
      },
      {
        "options": {
          "list": [
            "Instagram",
            "TikTok",
            "Snapchat",
            "X"
          ]
        },
        "name": "platform",
        "type": "string"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "name": "url",
        "type": "url",
        "title": "Link to Post"
      },
      {
        "name": "caption",
        "type": "string",
        "title": "Short Caption"
      }
    ],
    "name": "socialPost",
    "type": "document"
  }
]