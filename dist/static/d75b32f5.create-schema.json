[
  {
    "fields": [
      {
        "name": "name",
        "type": "string",
        "title": "Artist Name"
      },
      {
        "name": "logoText",
        "type": "string"
      },
      {
        "name": "logoImg",
        "type": "image",
        "title": "Logo Image"
      },
      {
        "of": [
          {
            "fields": [
              {
                "initialValue": true,
                "description": "ON = Fill/Crop. OFF = Full frame with glow.",
                "name": "fillContainer",
                "type": "boolean",
                "title": "Fill Container?"
              },
              {
                "options": {
                  "accept": "video/*"
                },
                "name": "videoFile",
                "type": "file"
              }
            ],
            "type": "object",
            "name": "videoEntry"
          }
        ],
        "name": "heroVideoPool",
        "type": "array"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "name": "spotifyUrl",
        "type": "url",
        "title": "Latest Release Link"
      },
      {
        "of": [
          {
            "lists": [
              {
                "value": "bullet",
                "title": "Bulleted list"
              },
              {
                "value": "number",
                "title": "Numbered list"
              }
            ],
            "marks": {
              "annotations": [
                {
                  "i18nTitleKey": "inputs.portable-text.annotation.link",
                  "options": {
                    "modal": {
                      "type": "popover"
                    }
                  },
                  "fields": [
                    {
                      "validation": [
                        {
                          "level": "error",
                          "rules": [
                            {
                              "flag": "uri",
                              "constraint": {
                                "options": {
                                  "scheme": [
                                    "/^http$/",
                                    "/^https$/",
                                    "/^tel$/",
                                    "/^mailto$/"
                                  ],
                                  "allowRelative": true,
                                  "relativeOnly": false,
                                  "allowCredentials": false
                                }
                              }
                            }
                          ]
                        }
                      ],
                      "description": "A valid web, email, phone, or relative link.",
                      "name": "href",
                      "type": "url",
                      "title": "Link"
                    }
                  ],
                  "name": "link",
                  "type": "object"
                }
              ],
              "decorators": [
                {
                  "value": "strong",
                  "title": "Strong"
                },
                {
                  "value": "em",
                  "title": "Italic"
                },
                {
                  "value": "code",
                  "title": "Code"
                },
                {
                  "value": "underline",
                  "title": "Underline"
                },
                {
                  "value": "strike-through",
                  "title": "Strike"
                }
              ]
            },
            "of": [],
            "styles": [
              {
                "value": "normal",
                "title": "Normal"
              },
              {
                "value": "h1",
                "title": "Heading 1"
              },
              {
                "value": "h2",
                "title": "Heading 2"
              },
              {
                "value": "h3",
                "title": "Heading 3"
              },
              {
                "value": "h4",
                "title": "Heading 4"
              },
              {
                "value": "h5",
                "title": "Heading 5"
              },
              {
                "value": "h6",
                "title": "Heading 6"
              },
              {
                "value": "blockquote",
                "title": "Quote"
              }
            ],
            "type": "block"
          }
        ],
        "name": "bio",
        "type": "array"
      }
    ],
    "name": "artist",
    "type": "document",
    "title": "Artist Profile"
  },
  {
    "fields": [
      {
        "name": "city",
        "type": "string"
      },
      {
        "name": "venue",
        "type": "string"
      },
      {
        "name": "date",
        "type": "datetime"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "name": "ticketUrl",
        "type": "url",
        "title": "Ticket URL"
      }
    ],
    "name": "tourDate",
    "type": "document"
  },
  {
    "fields": [
      {
        "options": {
          "hotspot": true
        },
        "name": "image",
        "type": "image",
        "title": "Post Image"
      },
      {
        "options": {
          "list": [
            "Instagram",
            "TikTok",
            "Snapchat",
            "X"
          ]
        },
        "name": "platform",
        "type": "string"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "uri",
                "constraint": {
                  "options": {
                    "scheme": [
                      "/^http$/",
                      "/^https$/"
                    ],
                    "allowRelative": false,
                    "relativeOnly": false,
                    "allowCredentials": false
                  }
                }
              }
            ]
          }
        ],
        "name": "url",
        "type": "url",
        "title": "Link to Post"
      },
      {
        "name": "caption",
        "type": "string",
        "title": "Short Caption"
      }
    ],
    "name": "socialPost",
    "type": "document"
  }
]